# ── Telegram ──────────────────────────────────────────────
TELEGRAM_TOKEN=pegar_token_de_BotFather_aqui

# ── Gemini (Google AI Studio) ─────────────────────────────
GEMINI_API_KEY=pegar_api_key_de_gemini_aqui

# ── Google Sheets ─────────────────────────────────────────
# El ID está en la URL del sheet:
# https://docs.google.com/spreadsheets/d/[ESTE_ES_EL_ID]/edit
GOOGLE_SHEETS_ID=pegar_id_del_sheet_aqui

# ── Tu Telegram User ID ───────────────────────────────────
# Mandá /getid al bot @userinfobot en Telegram para obtenerlo
ALLOWED_USER_ID=tu_user_id_numerico

# ── Solo para deploy en Render (dejar vacío en local) ─────
WEBHOOK_URL=
PORT=8000

# ── Solo para deploy en Render ────────────────────────────
# Pegar el contenido COMPLETO del archivo credentials.json como una sola línea
GOOGLE_CREDENTIALS_JSON=

# ── Dashboard (dashboard/main.py) ─────────────────────────
# Contraseña compartida para entrar al dashboard desde el navegador/iPhone
DASHBOARD_PASSWORD=

# Monto fijo de rendición a socios (70 cocheras al precio de hoy).
# Actualizar cuando cambie el precio por cochera.
RENDICION_OBJETIVO_BASE=9800000

# Cada cuánto se refresca el cache del dashboard contra Google Sheets (segundos)
SERIE_CACHE_TTL_SECONDS=120
PADRON_CACHE_TTL_SECONDS=300
